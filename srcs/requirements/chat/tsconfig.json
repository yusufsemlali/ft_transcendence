{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    // "paths": {
    //   "@chat/shared": ["../../packages/shared/src"],
    //   "@chat/shared/*": ["../../packages/shared/src/*"]
    // }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
